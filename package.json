{
  "name": "article-local-reader",
  "version": "1.0.0",
  "description": "PWA that reads any article aloud using on-device TTS",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/update-precache.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-icons": "node scripts/generate-icons.mjs",
    "worker:dev": "wrangler dev worker/index.ts",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "marked": "^18.0.0",
    "pdfjs-dist": "^5.6.205",
    "turndown": "^7.2.4",
    "youtube-transcript-plus": "^2.0.0"
  }
}
